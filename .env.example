# ─────────────────────────────────────────────────────────────
# Sonic Pro — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API
#
# NEVER commit .env to version control.
# Both variables are REQUIRED for cloud features to activate.
# The app works fully without them (local-only mode).

# Your Supabase project URL
# Example: https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=your_supabase_project_url_here

# Your Supabase anon/public key (safe to expose in client code)
# This is NOT the service_role key — never use service_role in the browser
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
